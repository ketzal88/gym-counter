{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Write(.claude/)",
      "Edit(.claude/)",
      "Write(CLAUDE.md)",
      "Edit(CLAUDE.md)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(git branch -D:*)",
      "Bash(git clean -fd:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import json,sys,subprocess,os; d=json.load(sys.stdin); cmd=d.get('tool_input',{}).get('command','') or ''; root=os.environ.get('CLAUDE_PROJECT_DIR','.'); sys.exit(subprocess.call([sys.executable, os.path.join(root,'scripts','check-no-secrets.py')], cwd=root)) if cmd.lstrip().startswith('git commit') else sys.exit(0)\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,sys,subprocess; root=os.environ.get('CLAUDE_PROJECT_DIR','.'); sys.exit(subprocess.call([sys.executable, os.path.join(root,'scripts','hook-post-edit.py')]))\""
          }
        ]
      }
    ]
  }
}
